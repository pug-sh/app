# Backend API base URL (ConnectRPC). Copy to .env.development / .env.production and adjust.
VITE_API_BASE_URL=http://localhost:3000

# Google OAuth on sign-in (requires backend OAuth env + allowlisted redirect URI).
VITE_OAUTH_GOOGLE_ENABLED=true
# Optional override; default is window.location.origin + /oauth/callback
# VITE_OAUTH_REDIRECT_URI=http://localhost:5173/oauth/callback
