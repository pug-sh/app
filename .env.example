# Backend API base URL (ConnectRPC). Copy to .env.development / .env.production and adjust.
VITE_API_BASE_URL=http://localhost:3000

# Public base URL for self-hosted map assets (basemap.pmtiles + glyph fonts). Production serves
# these from an object store (e.g. Cloudflare R2) because the basemap is ~500MB — too large for
# the static host. The bucket must allow CORS from the app origin and honour HTTP Range requests.
# Leave unset for local dev to serve the files from /public at the app origin. No trailing slash.
# VITE_MAP_ASSETS_URL=https://maps.example.com
