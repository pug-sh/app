# Backend API base URL (ConnectRPC). Copy to .env.development / .env.production and adjust.
VITE_API_BASE_URL=http://localhost:3000

# Public base URL for the self-hosted map assets (basemap PMTiles, glyph fonts, POV data),
# served from an object store (Cloudflare R2) behind the Cloudflare CDN because the basemap is
# ~500MB — too large for the static host. Dev and prod both use the CDN. The bucket must allow
# CORS and honour HTTP Range requests (see the pug-maps repo README). No trailing slash.
VITE_MAP_ASSETS_URL=https://maps.pug.sh

# Google sign-in via @react-oauth/google (requires backend Google OAuth client ID).
# Replaces the old redirect flow — VITE_OAUTH_REDIRECT_URI is no longer used.
# Sign-in is enabled whenever a client ID is set; leave blank to disable.
VITE_GOOGLE_CLIENT_ID=
