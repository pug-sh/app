# Backend API base URL (ConnectRPC). Copy to .env.development / .env.production and adjust.
VITE_API_BASE_URL=http://localhost:3000

# Public base URL for the self-hosted map assets (basemap PMTiles, glyph fonts, POV data),
# served from an object store (Cloudflare R2) behind the Cloudflare CDN because the basemap is
# ~500MB — too large for the static host. Dev and prod both use the CDN. The bucket must allow
# CORS and honour HTTP Range requests (see the pug-maps repo README). No trailing slash.
VITE_MAP_ASSETS_URL=https://maps.pug.sh

# Google sign-in via @react-oauth/google (requires backend Google OAuth client ID).
# Replaces the old redirect flow — VITE_OAUTH_REDIRECT_URI is no longer used.
# Sign-in is enabled whenever a client ID is set; leave blank to disable.
VITE_GOOGLE_CLIENT_ID=

# Read-only demo. Set to "true" to show the "Explore the live demo" link on the sign-in page. This
# only advertises the demo in the build; the real switch is the backend's PUG_DEMO_ENABLED. The
# /demo route still works without this flag (and shows an "unavailable" state when the server demo
# is off), and the in-app demo banner follows the active demo session, not this flag.
VITE_DEMO_ENABLED=

# Dogfooding — this dashboard reporting its own usage into Pug via @pug-sh/browser. Tracking is on
# only when BOTH are set, so an unset dev checkout sends nothing; set them to track. Events go to
# the SDK's default endpoint (https://api.pugs.dev), NOT to VITE_API_BASE_URL — a dev build with
# these set still reports to production Pug.
#
# The public key (pub_…) is baked into the bundle by design; never put a private key here. Both
# values MUST match pug-site's PUBLIC_PUG_* — cross-subdomain identity is stored under a
# project-scoped cookie key, so a different project on pug.sh means the visitor who lands there and
# the account they create here stay two unrelated strangers, and the signup funnel can't be followed.
VITE_PUG_PROJECT_ID=
VITE_PUG_PUBLIC_KEY=
